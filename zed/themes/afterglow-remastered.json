        "tab.inactive_background": "#292929ff",
        "tab.active_background": "#2e2e2eff",

        "panel.background": "#292929ff",

        "editor.background": "#2e2e2eff",
        "editor.foreground": "#d6d6d6ff",
        "editor.gutter.background": "#2e2e2eff",
