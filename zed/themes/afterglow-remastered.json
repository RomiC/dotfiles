          "operator": { "color": "#d6d6d6ff" },
          "predictive": { "color": "#8f8f8fff", "font_style": "italic" },
          "preproc": { "color": "#ff9834ff" },
          "primary": { "color": "#d6d6d6ff" },
          "property": { "color": "#d6d6d6ff" },
          "punctuation": { "color": "#d6d6d6ff" },
          "punctuation.bracket": { "color": "#d6d6d6ff" },
          "punctuation.delimiter": { "color": "#797979ff" },
          "punctuation.list_marker": { "color": "#c45837ff" },
          "punctuation.markup": { "color": "#6c99bbff" },
          "punctuation.special": { "color": "#a1617aff" },
          "selector": { "color": "#ffc66dff" },
          "selector.pseudo": { "color": "#cc7833ff" },
          "string": { "color": "#b4c973ff" },
          "string.escape": { "color": "#a1617aff" },
          "string.regex": { "color": "#b4c973ff" },
          "string.special": { "color": "#b4c973ff" },
          "string.special.symbol": { "color": "#6c99bbff" },
          "tag": { "color": "#ffc66dff" },
          "text.literal": { "color": "#b4c973ff" },
          "title": { "color": "#ffffffff", "font_weight": 700 },
          "type": { "color": "#6c99bbff" },
          "variable": { "color": "#d0d0ffff" },
          "variable.special": { "color": "#d6d6d6ff" },
          "variant": { "color": "#c45837ff" },
          "diff.plus": { "color": "#b4c973ff" },
          "diff.minus": { "color": "#c45837ff" }
