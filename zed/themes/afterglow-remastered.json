          "attribute": { "color": "#cc7833ff" },
          "boolean": { "color": "#b4c973ff" },
          "comment": { "color": "#797979ff" },
          "comment.doc": { "color": "#8a8a8aff" },
          "constant": { "color": "#6c99bbff" },
          "constructor": { "color": "#ffc66dff" },
          "embedded": { "color": "#d6d6d6ff" },
          "emphasis": { "color": "#ffc66dff", "font_style": "italic" },
