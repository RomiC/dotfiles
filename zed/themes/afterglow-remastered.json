{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Afterglow Remastered",
  "author": "Marvin Hagemeister, adapted for Zed by Codex",
  "themes": [
    {
      "name": "Afterglow Remastered",
