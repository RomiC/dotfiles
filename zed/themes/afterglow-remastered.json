        "border.focused": "#6c99bbff",
        "border.selected": "#5a647eff",
        "border.transparent": "#00000000",
        "border.disabled": "#3b3b3bff",

        "element.background": "#343434ff",
        "element.hover": "#3d3d3dff",
        "element.active": "#454545ff",
        "element.selected": "#454545ff",
        "element.disabled": "#303030ff",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#3d3d3dff",
        "ghost_element.active": "#454545ff",
        "ghost_element.selected": "#454545ff",
        "ghost_element.disabled": "#303030ff",

        "text": "#d6d6d6ff",
