        "info.border": "#6c99bb80",
        "success": "#b4c973ff",
        "success.background": "#b4c97320",
        "success.border": "#b4c97380",
        "hint": "#a1617aff",
        "hint.background": "#a1617a20",
        "hint.border": "#a1617a80",

