        "text.accent": "#6c99bbff",

        "icon": "#d6d6d6ff",
        "icon.muted": "#979797ff",
        "icon.disabled": "#777777ff",
        "icon.placeholder": "#979797ff",
        "icon.accent": "#6c99bbff",

