          { "cursor": "#ffc66dff", "background": "#ffc66dff", "selection": "#ffc66d33" },
          { "cursor": "#b4c973ff", "background": "#b4c973ff", "selection": "#b4c97333" },
          { "cursor": "#c45837ff", "background": "#c45837ff", "selection": "#c4583733" },
          { "cursor": "#a1617aff", "background": "#a1617aff", "selection": "#a1617a33" }
